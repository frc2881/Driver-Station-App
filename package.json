{
  "name": "frc-driver-station-app",
  "description": "FRC driver station app for HUD and dashboard",
  "version": "2026.8.0",
  "author": "frc2881",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "app/main.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm-run-all build:*",
    "build:init": "node scripts/build-init.mjs",
    "build:main": "tsc -p tsconfig-main.json",
    "build:ui": "rollup -c",
    "dist": "electron-builder --win",
    "package": "npm-run-all build dist",
    "start": "electron .",
    "dev": "npm-run-all build --parallel watch \"start -- {1}\" --",
    "watch": "rollup -cw"
  },
  "build": {
    "appId": "FRC.DriverStationApp.2026.8.0",
    "productName": "FRCDriverStationApp",
    "copyright": "Copyright (c) FRC Team 2881",
    "win": {
      "target": "portable",
      "artifactName": "${productName}-${version}.${ext}",
      "compression": "store",
      "icon": "resources/app-icon.png"
    }
  },
  "dependencies": {
    "ws": "8.20.0",
    "@msgpack/msgpack": "3.1.3"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "npm-run-all": "4.1.5",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "@electron/packager": "20.0.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "rollup": "4.60.2",
    "rollup-plugin-css-only": "4.5.5",
    "rollup-plugin-svelte": "7.2.3",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@rollup/plugin-replace": "6.0.3",
    "postcss": "8.5.10",
    "svelte": "5.55.5",
    "svelte-preprocess": "6.0.3",
    "carbon-preprocess-svelte": "0.11.30",
    "carbon-components-svelte": "0.106.2",
    "carbon-icons-svelte": "13.10.0",
    "carbon-pictograms-svelte": "13.16.0"
  },
  "engines": {
    "node": "24.14.1"
  },
  "volta": {
    "node": "24.14.1"
  }
}
